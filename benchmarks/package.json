{
  "name": "benchmarks",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "pnpm generate && next dev --webpack",
    "dev:turbo": "pnpm generate && next dev",
    "build": "pnpm build:yak && pnpm generate && pnpm build:next",
    "build:turbo": "pnpm build:yak && pnpm generate && pnpm build:next:turbo",
    "build:next": "next build --webpack",
    "build:next:turbo": "next build",
    "build:yak": "pnpm --filter next-yak build",
    "start": "next start",
    "generate": "pnpm run \"/^generate:bench:/\" --parallel",
    "generate:bench:kanji-letter": "tsx ./bench/kanji-letter/gen.ts",
    "generate:bench:pure-components": "tsx ./bench/pure-components/gen.ts",
    "generate:bench:attrs-components": "tsx ./bench/attrs-components/gen.ts",
    "generate:bench:css-prop": "tsx ./bench/css-prop/gen.ts",
    "generate:bench:dynamic-props": "tsx ./bench/dynamic-props/gen.ts",
    "generate:bench:nested-components": "tsx ./bench/nested-components/gen.ts",
    "generate:bench:tree": "tsx ./bench/tree/gen.ts",
    "generate:bench:sierpinski": "tsx ./bench/sierpinski/gen.ts",
    "generate:bench:cross-request-cache": "tsx ./bench/cross-request-cache/gen.ts",
    "generate:bench:tree-deep": "tsx ./bench/tree-deep/gen.ts",
    "generate:bench:tree-wide": "tsx ./bench/tree-wide/gen.ts",
    "generate:bench:idiomatic-tree": "tsx ./bench/idiomatic-tree/gen.ts",
    "generate:bench:idiomatic-dynamic-props": "tsx ./bench/idiomatic-dynamic-props/gen.ts",
    "bench": "pnpm generate && pnpm bench:build && pnpm bench:run",
    "bench:build": "tsdown ./bench/index.bench.tsx --no-config --sourcemap --minify --env.NODE_ENV=production --format esm --target node20 --out-dir ./bench/dist --deps.neverBundle benchmark --deps.neverBundle styled-components --deps.neverBundle react --deps.neverBundle react-dom",
    "bench:run": "NODE_ENV=production node --enable-source-maps ./bench/dist/index.bench.mjs",
    "bench:profile:build": "tsdown ./bench/profile.tsx --no-config --sourcemap --env.NODE_ENV=production --format esm --target node20 --out-dir ./bench/dist-profile --deps.neverBundle styled-components --deps.neverBundle react --deps.neverBundle react-dom",
    "bench:profile": "NODE_ENV=production node --cpu-prof --cpu-prof-dir=./bench/profiles --enable-source-maps ./bench/dist-profile/profile.mjs",
    "bench:profile:heap": "NODE_ENV=production node --heap-prof --heap-prof-dir=./bench/profiles --enable-source-maps ./bench/dist-profile/profile.mjs",
    "bench:profile:analyze": "node ./bench/analyze-cpuprofile.mjs"
  },
  "dependencies": {
    "@swc/core": "catalog:core",
    "next": "catalog:dev",
    "next-yak": "workspace:*",
    "react": "catalog:dev",
    "react-dom": "catalog:dev",
    "styled-components": "catalog:dev",
    "yak-swc": "workspace:*"
  },
  "devDependencies": {
    "@types/benchmark": "catalog:dev",
    "@types/react": "catalog:dev",
    "@types/react-dom": "catalog:dev",
    "benchmark": "catalog:dev",
    "tsdown": "catalog:dev",
    "tsx": "catalog:dev",
    "typescript": "catalog:dev"
  }
}
