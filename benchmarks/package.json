{
  "name": "benchmarks",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "pnpm generate && next dev --webpack",
    "dev:turbo": "pnpm generate && next dev",
    "build": "pnpm build:yak && pnpm generate && pnpm build:next",
    "build:turbo": "pnpm build:yak && pnpm generate && pnpm build:next:turbo",
    "build:next": "next build --webpack",
    "build:next:turbo": "next build",
    "build:yak": "pnpm --filter next-yak build",
    "start": "next start",
    "generate": "pnpm run \"/^generate:codspeed:/\" --parallel",
    "generate:codspeed:kanji-letter": "tsx ./codspeed/kanji-letter/gen.ts",
    "generate:codspeed:pure-components": "tsx ./codspeed/pure-components/gen.ts",
    "generate:codspeed:attrs-components": "tsx ./codspeed/attrs-components/gen.ts",
    "generate:codspeed:css-prop": "tsx ./codspeed/css-prop/gen.ts",
    "generate:codspeed:dynamic-props": "tsx ./codspeed/dynamic-props/gen.ts",
    "generate:codspeed:nested-components": "tsx ./codspeed/nested-components/gen.ts",
    "generate:codspeed:tree": "tsx ./codspeed/tree/gen.ts",
    "generate:codspeed:sierpinski": "tsx ./codspeed/sierpinski/gen.ts",
    "generate:codspeed:cross-request-cache": "tsx ./codspeed/cross-request-cache/gen.ts",
    "generate:codspeed:tree-deep": "tsx ./codspeed/tree-deep/gen.ts",
    "generate:codspeed:tree-wide": "tsx ./codspeed/tree-wide/gen.ts",
    "generate:codspeed:idiomatic-tree": "tsx ./codspeed/idiomatic-tree/gen.ts",
    "generate:codspeed:idiomatic-dynamic-props": "tsx ./codspeed/idiomatic-dynamic-props/gen.ts",
    "codspeed": "pnpm generate && pnpm codspeed:build && pnpm codspeed:run",
    "codspeed:build": "tsdown ./codspeed/index.bench.tsx --no-config --sourcemap --minify --env.NODE_ENV=production --format esm --target node20 --out-dir ./codspeed/dist --deps.neverBundle benchmark --deps.neverBundle styled-components --deps.neverBundle react --deps.neverBundle react-dom --deps.neverBundle @codspeed/benchmark.js-plugin",
    "codspeed:run": "NODE_ENV=production node ./codspeed/dist/index.bench.mjs"
  },
  "dependencies": {
    "@swc/core": "catalog:core",
    "next": "catalog:dev",
    "next-yak": "workspace:*",
    "react": "catalog:dev",
    "react-dom": "catalog:dev",
    "styled-components": "catalog:dev",
    "yak-swc": "workspace:*"
  },
  "devDependencies": {
    "@codspeed/benchmark.js-plugin": "catalog:dev",
    "@types/benchmark": "catalog:dev",
    "@types/react": "catalog:dev",
    "@types/react-dom": "catalog:dev",
    "benchmark": "catalog:dev",
    "tsdown": "catalog:dev",
    "tsx": "catalog:dev",
    "typescript": "catalog:dev"
  }
}
