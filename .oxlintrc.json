{
  "$schema": "https://raw.githubusercontent.com/oxc-project/oxc/main/npm/oxlint/configuration_schema.json",
  "plugins": ["typescript", "unicorn", "oxc", "import", "react"],
  "jsPlugins": ["eslint-plugin-yak"],
  "categories": {
    "correctness": "error"
  },
  "rules": {
    "no-empty": ["error", { "allowEmptyCatch": true }],
    "no-var": "off",
    "no-control-regex": "off",
    "typescript/no-empty-object-type": "off",
    "yak/css-nesting-operator": "error",
    "yak/css-global-deprecated": "warn",
    "yak/enforce-semicolon": "error",
    "yak/style-conditions": "warn"
  },
  "overrides": [
    {
      "files": ["**/*.test.*", "**/*.bench.*", "**/__tests__/**"],
      "rules": {
        "no-unused-vars": "off",
        "no-unused-expressions": "off",
        "no-constant-binary-expression": "off",
        "no-constant-condition": "off",
        "typescript/triple-slash-reference": "off",
        "oxc/number-arg-out-of-range": "off",
        "yak/enforce-semicolon": "off",
        "yak/style-conditions": "off"
      }
    },
    {
      "files": ["examples/**"],
      "rules": {
        "no-constant-binary-expression": "off"
      }
    }
  ],
  "ignorePatterns": [
    "**/dist/**",
    "**/.next/**",
    "**/.swc/**",
    "**/.tanstack/**",
    "**/.vercel/**",
    "**/node_modules/**",
    "**/out/**",
    "**/target/**",
    "benchmarks/**",
    "cross-file-tests/__tests__/.tmp/**",
    "packages/yak-swc/yak_swc/tests/fixture/**",
    "packages/next-yak/isolated-source-eval/__tests__/fixtures/syntax-error.ts",
    "e2e/**",
    "docs/**"
  ]
}
