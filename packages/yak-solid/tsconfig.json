{
  "compilerOptions": {
    "paths": {
      "@yak/solid": ["./runtime/index.ts"],
      "@yak/solid/context/baseContext": ["./runtime/context/baseContext.ts"],
      "@yak/solid/context": ["./runtime/context/index.ts"]
    },
    "target": "ES2022",
    "lib": ["DOM", "ESNext"],
    "types": ["node"],
    "jsx": "preserve",
    "jsxImportSource": "@solidjs/web",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "noEmit": true,
    "allowImportingTsExtensions": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true
  },
  "exclude": ["**/node_modules/**/*", "**/__tests__/**/*"],
  "include": ["runtime/**/*", "loaders/**/*"]
}
